    {
      "name": "LastGuess_Winner_Player2",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "if (pm.response.code === 200) {\r",
              "    const jsonData = pm.response.json();\r",
              "\r",
              "    const player1 = jsonData.players.find(p => p.id === pm.environment.get(\"player1Id\"));\r",
              "    const player2 = jsonData.players.find(p => p.id === pm.environment.get(\"player2Id\"));\r",
              "    const winner = jsonData.players.find(p => p.id === jsonData.winnerId);\r",
              "\r",
              "    pm.test(\"Game id is correct\", function () {\r",
              "        pm.expect(jsonData.id).to.eql(pm.environment.get(\"gameId\"));\r",
              "    });\r",
              "\r",
              "    pm.test(\"State is GameFinished\", function () {\r",
              "        pm.expect(jsonData.state).to.eql(\"GameFinished\");\r",
              "    });\r",
              "\r",
              "    pm.test(\"Masked word is fully revealed\", function () {\r",
              "        pm.expect(jsonData.maskedWord).to.eql(\"APPLE\");\r",
              "        pm.expect(jsonData.maskedWord).to.not.include(\"_\");\r",
              "    });\r",
              "\r",
              "    pm.test(\"Guessed letters contains E\", function () {\r",
              "        pm.expect(jsonData.guessedLetters).to.include(\"E\");\r",
              "    });\r",
              "\r",
              "    pm.test(\"Players array contains 2 players\", function () {\r",
              "        pm.expect(jsonData.players).to.be.an(\"array\");\r",
              "        pm.expect(jsonData.players.length).to.eql(2);\r",
              "    });\r",
              "\r",
              "    pm.test(\"Player1 and Player2 exist in response\", function () {\r",
              "        pm.expect(player1).to.exist;\r",
              "        pm.expect(player2).to.exist;\r",
              "    });\r",
              "\r",
              "    pm.test(\"Player numbers are correct\", function () {\r",
              "        pm.expect(player1.playerNumber).to.eql(1);\r",
              "        pm.expect(player2.playerNumber).to.eql(2);\r",
              "    });\r",
              "\r",
              "    pm.test(\"Scores are correct for APPLE flow\", function () {\r",
              "        pm.expect(player1.score).to.eql(6);\r",
              "        pm.expect(player2.score).to.eql(10);\r",
              "    });\r",
              "\r",
              "    pm.test(\"Game is not a draw\", function () {\r",
              "        pm.expect(jsonData.isDraw).to.eql(false);\r",
              "    });\r",
              "\r",
              "    pm.test(\"Winner is player2\", function () {\r",
              "        pm.expect(jsonData.winnerId).to.eql(pm.environment.get(\"player2Id\"));\r",
              "        pm.expect(winner).to.exist;\r",
              "        pm.expect(winner.playerNumber).to.eql(2);\r",
              "    });\r",
              "\r",
              "    pm.environment.set(\"gameState\", jsonData.state);\r",
              "    pm.environment.set(\"winnerId\", jsonData.winnerId ?? \"\");\r",
              "    pm.environment.set(\"isDraw\", jsonData.isDraw);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
