    {
      "name": "Guess_Player1_Valid",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "if (pm.response.code === 200) {\r",
              "    const jsonData = pm.response.json();\r",
              "\r",
              "    pm.test(\"Response contains game id\", function () {\r",
              "        pm.expect(jsonData.id).to.exist;\r",
              "    });\r",
              "\r",
              "    pm.test(\"State exists\", function () {\r",
              "        pm.expect(jsonData.state).to.exist;\r",
              "    });\r",
              "\r",
              "    pm.test(\"Current player id exists\", function () {\r",
              "        pm.expect(jsonData.currentPlayerId).to.exist;\r",
              "    });\r",
              "\r",
              "    pm.test(\"Players list has 2 players\", function () {\r",
              "        pm.expect(jsonData.players.length).to.eql(2);\r",
              "    });\r",
              "\r",
              "    pm.test(\"Guessed letters contains guessed letter\", function () {\r",
              "        pm.expect(jsonData.guessedLetters).to.include(\"A\");\r",
              "    });\r",
              "\r",
              "    pm.test(\"Turn changed to player 2 unless game finished\", function () {\r",
              "        if (jsonData.state !== \"GameFinished\") {\r",
              "            pm.expect(jsonData.currentPlayerId).to.eql(pm.environment.get(\"player2Id\"));\r",
              "        }\r",
              "    });\r",
              "\r",
              "    pm.environment.set(\"lastGuessedLetter\", \"A\");\r",
              "    pm.environment.set(\"currentPlayerId\", jsonData.currentPlayerId);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
