@page "/"
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject HttpClient Http

<PageTitle>LetterDuel</PageTitle>

<div class="container mt-5">
    <h1 class="text-center mb-4">⚔️ LetterDuel</h1>

    @if (createdGameId == "")
    {
        <div class="row justify-content-center">
            <div class="col-md-4 text-center">
                <button class="btn btn-primary btn-lg w-100 mb-3" @onclick="CreateGame">
                    Create Game
                </button>

                <hr />

                <input class="form-control mb-2" placeholder="Enter Game ID" @bind="joinGameId" />
                <button class="btn btn-secondary w-100" @onclick="JoinGame">
                    Join Game
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="row justify-content-center">
            <div class="col-md-5 text-center">
                <div class="alert alert-success">
                    <p class="mb-1">Game created! Share this link with Player 2:</p>
                    <strong>@joinLink</strong>
                </div>
                <button class="btn btn-outline-secondary btn-sm mb-3" @onclick="CopyLink">
                    📋 Copy Link
                </button>
                <br />
                <button class="btn btn-primary w-100" @onclick="GoToGame">
                    Enter Game as Player 1
                </button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter, SupplyParameterFromQuery]
    public string? Join { get; set; }

    private string joinGameId = "";
    private string createdGameId = "";
    private string joinLink = "";

    private record CreateGameResponse(Guid GameId, Guid PlayerId, string PlayerName);
    private record JoinGameResponse(Guid GameId, Guid PlayerId, string PlayerName);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !string.IsNullOrEmpty(Join))
        {
            await JoinAndNavigate(Join);
        }
    }

    private async Task CreateGame()
    {
        try
        {
            var response = await Http.PostAsJsonAsync("api/games",
            new { PlayerName = "Player1" });

            if (!response.IsSuccessStatusCode) return;

            var result = await response.Content
                .ReadFromJsonAsync<CreateGameResponse>();

            if (result == null) return;

            await JS.InvokeVoidAsync("localStorage.setItem", "gameId", result.GameId.ToString());
            await JS.InvokeVoidAsync("localStorage.setItem", "playerId", result.PlayerId.ToString());

            createdGameId = result.GameId.ToString();
            joinLink = $"{Nav.BaseUri}?join={createdGameId}";
        }
        catch
        {
            // TODO: visa felmeddelande om API inte svarar
        }
    }

    private async Task JoinGame()
    {
        await JoinAndNavigate(joinGameId);
    }

    private async Task JoinAndNavigate(string gameId)
    {
        try
        {
            var response = await Http.PostAsJsonAsync($"api/games/{gameId}/join",
    new { PlayerName = "Player2" });

            if (!response.IsSuccessStatusCode) return;

            var result = await response.Content
                .ReadFromJsonAsync<JoinGameResponse>();

            if (result == null) return;

            await JS.InvokeVoidAsync("localStorage.setItem", "gameId", result.GameId.ToString());
            await JS.InvokeVoidAsync("localStorage.setItem", "playerId", result.PlayerId.ToString());

            Nav.NavigateTo($"/game/{gameId}");
        }
        catch
        {
            // TODO: visa felmeddelande om API inte svarar
        }
    }

    private void GoToGame()
    {
        Nav.NavigateTo($"/game/{createdGameId}");
    }

    private async Task CopyLink()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", joinLink);
    }
}