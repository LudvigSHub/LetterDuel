@page "/game/{GameId}"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IAsyncDisposable

<PageTitle>LetterDuel - Game</PageTitle>

<div class="container mt-4">

    <!-- 
        Visar vilket player number du är
        myPlayerNumber sätts slumpmässigt nu, ska komma från API (playerId matchas mot players-listan)
    -->
    <div class="text-center mb-3">
        <span class="badge @(myPlayerNumber == 1 ? "bg-primary" : "bg-danger") fs-6">
            You are Player @myPlayerNumber
        </span>
    </div>

    <!--
        Visar poäng och vems tur det är
         player1Score och player2Score kommer från dummy, ska komma från API via RefreshGameState
         currentTurn är lokal, ska baseras på currentPlayerId från API(?)
    -->
    <div class="row text-center mb-4">
        <div class="col">
            <h5>Player 1</h5>
            <span class="badge bg-primary fs-5">@player1Score p</span>
            @if (currentTurn == 1)
            {
                <div>
                    <span class="badge bg-success mt-1">
                        @(myPlayerNumber == 1 ? "Your turn!" : "Their turn")
                    </span>
                </div>
            }
        </div>
        <div class="col-auto align-self-center">
            <h5>VS</h5>
        </div>
        <div class="col">
            <h5>Player 2</h5>
            <span class="badge bg-danger fs-5">@player2Score p</span>
            @if (currentTurn == 2)
            {
                <div>
                    <span class="badge bg-success mt-1">
                        @(myPlayerNumber == 2 ? "Your turn!" : "Their turn")
                    </span>
                </div>
            }
        </div>
    </div>

    <!--
        Visar ordets bokstäver som rutor
        maskedWord kommer från dummydatan ("APPLE"), ska komma från API
        
    -->
    <div class="text-center mb-4">
        <div class="d-flex justify-content-center gap-2 flex-wrap">
            @foreach (var ch in maskedWord)
            {
                <div class="border border-2 d-flex align-items-center justify-content-center"
                     style="width:50px;height:60px;font-size:1.8rem;font-weight:bold;">
                    @(ch == '_' ? "" : ch.ToString())
                </div>
            }
        </div>
    </div>

    <!--
        Visar gissade bokstäver
                guessedLetters ska komma från API, inte lokal lista
    -->
    <div class="text-center mb-4">
        <p><strong>Guessed letters:</strong>
            @foreach (var letter in guessedLetters)
            {
                <!-- 
                    färgkoda bokstäverna om vi vill
                    behövs att vi vet om bokstaven var rätt eller fel dvs behöver eget state eller info från API
                -->
                <span class="badge @(correctLetters.Contains(letter) ? "bg-success" : "bg-secondary") me-1">
                    @letter
                </span>
            }
        </p>
    </div>

    <!--
        input visas bara när det är din tur, annars "Waiting..."
        currentTurn == myPlayerNumber fungerar med dummy,
              ska jämföra currentPlayerId från API mot din playerId från localStorage
        
    -->
    <div class="row justify-content-center mb-3">
        <div class="col-md-3 text-center">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <!-- visar felmeddelande vid ogiltig gissning -->
                <div class="alert alert-danger py-1 mb-2">@errorMessage</div>
            }

            @if (currentTurn == myPlayerNumber)
            {
                <input class="form-control text-center mb-2"
                       maxlength="1"
                       placeholder="A-Z"
                       @bind="currentGuess" />
                <button class="btn btn-success w-100" @onclick="MakeGuess" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <!-- laddning kanske? -->
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Guess!
                </button>
            }
            else
            {
                <p class="text-muted fst-italic">Waiting for other player...</p>
            }
        </div>
    </div>

    <!--
        visa Game ID så spelare 1 kan dela det
        
    -->
    <div class="text-center mt-4">
        <small class="text-muted">Game ID: <strong>@GameId</strong></small>
    </div>

</div>

@code {
    [Parameter] public string GameId { get; set; } = "";

    [Parameter, SupplyParameterFromQuery]
    public int? Player { get; set; }

    private string playerToken = "";
    private int myPlayerNumber = 0;

    // dummy data
    // allt detta ska ersättas med data från API
    private int player1Score = 0;
    private int player2Score = 0;
    private int currentTurn = 1;
    private string secretWord = "APPLE";
    private List<char> maskedWord = new();
    private List<string> guessedLetters = new();

    // håller koll på rätta gissningar för färgkodning
    private HashSet<string> correctLetters = new();

    private string currentGuess = "";
    private string errorMessage = "";  //felmeddelanden
    private bool isLoading = false;    // laddningsgrejsimojs

    private Timer? _timer;

    protected override void OnInitialized()
    {
        maskedWord = secretWord.Select(_ => '_').ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            playerToken = await JS.InvokeAsync<string>("localStorage.getItem", "playerToken") ?? "";

            //  ersätt med API-anrop som kollar vilket playernumber din token motsvarar
            myPlayerNumber = Player ?? 1;

            _timer = new Timer(async _ =>
            {
                await RefreshGameState();
                await InvokeAsync(StateHasChanged);
            }, null, 0, 800);

            StateHasChanged();
        }
    }

    private async Task RefreshGameState()
    {
        // anropa GET /api/games/{GameId} med playerToken som header
        // och uppdatera: maskedWord, guessedLetters, player1Score, player2Score, currentTurn
        // när state == "GameFinished": navigera till resultatsida
        await Task.CompletedTask;
    }

    private void MakeGuess()
    {
        // rensa felmeddelande vid nytt försök
        errorMessage = "";

        if (string.IsNullOrWhiteSpace(currentGuess)) return;

        var letter = currentGuess.ToUpper()[0];

        // validera redan gissad bokstav direkt i UI
        if (guessedLetters.Contains(letter.ToString()))
        {
            errorMessage = $"{letter} has already been guessed!";
            currentGuess = "";
            return;
        }

        guessedLetters.Add(letter.ToString());

        bool isCorrect = false;
        for (int i = 0; i < secretWord.Length; i++)
        {
            if (secretWord[i] == letter)
            {
                maskedWord[i] = letter;
                isCorrect = true;
            }
        }

        // spara rätt gissningar för färgkodning
        if (isCorrect)
        {
            correctLetters.Add(letter.ToString());
            bool isVowel = "AEIOUY".Contains(letter);
            if (currentTurn == 1) player1Score += isVowel ? 2 : 4;
            else player2Score += isVowel ? 2 : 4;
        }

        currentTurn = currentTurn == 1 ? 2 : 1;
        currentGuess = "";

        // när API finns, ersätt hela MakeGuess med ett POST-anrop
        // och låt RefreshGameState uppdatera state istället :)
    }

    public async ValueTask DisposeAsync()
    {
        if (_timer != null)
            await _timer.DisposeAsync();
    }
}